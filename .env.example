DATABASE_URL=postgresql+asyncpg://hangar:hangar@postgres:5432/hangar
HANGAR_ADMIN_TOKEN=change-me
ANTHROPIC_API_KEY=

# Optional: override session output path (defaults to ./.hangar/sessions
# which is mounted via docker-compose.yml). Use absolute paths only.
# HANGAR_DOCKER_HOST_SESSIONS_ROOT=/absolute/path/to/hangar/.hangar/sessions

# Optional: override the base image used for session containers.
# If you set this to anything other than python:3.12-slim, your image
# MUST include claude-agent-sdk>=0.1.76.
# HANGAR_SESSION_BASE_IMAGE=python:3.12-slim

# Optional: set to 0 to reject the dev-only `hgr_test_key` API key.
# Required for any deployment beyond localhost.
# HANGAR_ACCEPT_TEST_KEY=1

# Optional: set to 0 to disable the Claude Agent SDK and use the
# deterministic fallback harness for testing.
# HANGAR_USE_CLAUDE_AGENT_SDK=1

# Optional: set to 0 to use the local asyncio runtime instead of DBOS.
# The local runtime loses durability across restarts.
# HANGAR_ENABLE_DBOS=1
